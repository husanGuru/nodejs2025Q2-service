FROM postgres:17

# Optional: copy initialization scripts into the container
# These scripts run automatically on container startup (if in /docker-entrypoint-initdb.d)
COPY ./init-scripts/ /docker-entrypoint-initdb.d/

# Optional: add custom config file (e.g., postgresql.conf)
# COPY ./custom-postgresql.conf /etc/postgresql/postgresql.conf
# RUN echo "include '/etc/postgresql/postgresql.conf'" >> /usr/share/postgresql/postgresql.conf.sample

EXPOSE 5432